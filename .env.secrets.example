# Local secrets override.
# Copy to `.env.local` or `.env.secrets` on your machine.
# This file is loaded after the tracked `.env` and overrides any duplicate keys.

PRIVATE_KEY=
FUNDER_ADDRESS=

CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

DISCORD_WEBHOOK_URL=

# Optional operator-only values. The bot itself does not currently read these,
# but you may keep them here for your own deployment workflow.
RELAYER_URL=
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
PROXY_WALLET=
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=
